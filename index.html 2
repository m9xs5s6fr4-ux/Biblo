<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<title>Biblo – Dein Bibelbegleiter</title>
<style>
  body {
    font-family: Arial, sans-serif;
    background-color: #f7f7f8;
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100vh;
    margin: 0;
  }

  .chat-container {
    width: 400px;
    height: 600px;
    border-radius: 10px;
    background-color: white;
    box-shadow: 0 0 20px rgba(0,0,0,0.1);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .chat-header {
    padding: 15px;
    background-color: #343541;
    color: white;
    font-weight: bold;
    text-align: center;
  }

  .chat-messages {
    flex: 1;
    padding: 10px;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
  }

  .message {
    max-width: 80%;
    padding: 10px 15px;
    margin: 5px 0;
    border-radius: 15px;
    word-wrap: break-word;
  }

  .user {
    align-self: flex-end;
    background-color: #1a73e8;
    color: white;
  }

  .bot {
    align-self: flex-start;
    background-color: #e5e5ea;
    color: black;
  }

  .chat-input {
    display: flex;
    border-top: 1px solid #ddd;
  }

  .chat-input textarea {
    flex: 1;
    border: none;
    padding: 10px;
    font-size: 16px;
    resize: none;
  }

  .chat-input button {
    background-color: #1a73e8;
    color: white;
    border: none;
    padding: 0 20px;
    cursor: pointer;
    font-size: 16px;
  }

  .chat-input button:hover {
    background-color: #155bb5;
  }
</style>
</head>
<body>
  <div class="chat-container">
    <div class="chat-header">Biblo – Dein Bibelbegleiter</div>
    <div class="chat-messages" id="chatMessages"></div>
    <div class="chat-input">
      <textarea id="userInput" placeholder="Schreibe deine Frage..."></textarea>
      <button onclick="sendMessage()">Senden</button>
    </div>
  </div>

  <script>
    async function sendMessage() {
      const input = document.getElementById("userInput");
      const chat = document.getElementById("chatMessages");
      const question = input.value.trim();
      if (!question) return;

      // Add user message
      const userMsg = document.createElement("div");
      userMsg.className = "message user";
      userMsg.innerText = question;
      chat.appendChild(userMsg);
      chat.scrollTop = chat.scrollHeight;

      input.value = "";

      // Add bot placeholder
      const botMsg = document.createElement("div");
      botMsg.className = "message bot";
      botMsg.innerText = "Biblo denkt... ⏳";
      chat.appendChild(botMsg);
      chat.scrollTop = chat.scrollHeight;

      // Call OpenAI API
      const response = await fetch("https://api.openai.com/v1/responses", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "Authorization": "Bearer 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"
        },
        body: JSON.stringify({
          model: "gpt-4.1-mini",
          input: "Du bist Biblo, ein freundlicher und bibeltreuer Bibelbegleiter. Hilf Menschen, eine tiefere Beziehung zu Jesus zu entwickeln. Frage: " + question
        })
      });

      const data = await response.json();
      const answer = data.output?.[0]?.content?.[0]?.text || "Biblo konnte leider keine Antwort geben.";
      botMsg.innerText = answer;
      chat.scrollTop = chat.scrollHeight;
    }
  </script>
</body>
</html>
