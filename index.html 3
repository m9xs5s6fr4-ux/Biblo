        <p className="text-gray-300 text-sm">{text}</p>
      </div>
    </div>
  );
}

function QuizSection() {
  const questions = [
    {
      question: "Womit besiegte David Goliath?",
      options: ["Schwert", "Schleuder", "Speer"],
      answer: "Schleuder",
    },
    {
      question: "Wie viele Tage regnete es bei Noah?",
      options: ["7 Tage", "40 Tage", "100 Tage"],
      answer: "40 Tage",
    },
    {
      question: "Was tat Jesus, als der Sturm tobte?",
      options: ["Er schlief", "Er rannte weg", "Er weinte"],
      answer: "Er schlief",
    },
  ];

  const [current, setCurrent] = useState(0);
  const [score, setScore] = useState(0);
  const [finished, setFinished] = useState(false);

  const handleAnswer = (option) => {
    if (option === questions[current].answer) {
      setScore(score + 1);
    }

    const next = current + 1;
    if (next < questions.length) {
      setCurrent(next);
    } else {
      setFinished(true);
    }
  };

  return (
    <section className="max-w-3xl mx-auto mt-20 bg-white/10 backdrop-blur-md rounded-2xl p-8 shadow-xl">
      <h2 className="text-2xl md:text-3xl font-semibold mb-6 text-center">Bibel Quiz</h2>

      {finished ? (
        <div className="text-center">
          <p className="text-xl mb-4">Du hast {score} von {questions.length} Fragen richtig 🎉</p>
          <button
            onClick={() => {
              setCurrent(0);
              setScore(0);
              setFinished(false);
            }}
            className="bg-purple-600 px-6 py-2 rounded-xl hover:bg-purple-700 transition"
          >
            Nochmal spielen
          </button>
        </div>
      ) : (
        <div>
          <p className="mb-6 text-lg">{questions[current].question}</p>
          <div className="grid gap-3">
            {questions[current].options.map((option) => (
              <button
                key={option}
                onClick={() => handleAnswer(option)}
                className="bg-indigo-600 px-4 py-2 rounded-xl hover:bg-indigo-700 transition"
              >
                {option}
              </button>
            ))}
          </div>
        </div>
      )}
    </section>
  );
}

function StoryCard({ title, image, text }) {
  return (
    <div className="bg-white/10 rounded-2xl overflow-hidden shadow-lg hover:scale-105 transition-transform duration-300">
      <img src={image} alt={title} className="w-full h-48 object-cover" />
      <div className="p-6">
        <h3 className="text-xl font-semibold mb-2">{title}</h3>
        <p className="text-gray-300 text-sm">{text}</p>
      </div>
    </div>
  );
}
