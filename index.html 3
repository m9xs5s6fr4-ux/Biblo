import { useState } from "react";

export default function BibelheftWebsite() {
  return (
    <div className="min-h-screen bg-gradient-to-br from-indigo-900 via-purple-900 to-slate-900 text-white p-6">
      <header className="text-center py-10">
        <h1 className="text-4xl md:text-6xl font-bold mb-4">BibelStories</h1>
        <p className="text-lg md:text-xl text-gray-300">Geschichten, die dein Leben verändern können ✨</p>
      </header>

      <section className="grid md:grid-cols-3 gap-6 max-w-6xl mx-auto">
        <StoryCard
          title="David & Goliath"
          image="https://images.unsplash.com/photo-1500530855697-b586d89ba3ee"
          text="Manchmal wirken Probleme riesig – doch Mut und Vertrauen machen stark."
        />

        <StoryCard
          title="Noah & der Neuanfang"
          image="https://images.unsplash.com/photo-1507525428034-b723cf961d3e"
          text="Nach jedem Sturm kommt Hoffnung."
        />

        <StoryCard
          title="Jesus beruhigt den Sturm"
